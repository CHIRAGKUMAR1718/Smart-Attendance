# Local development — copy to .env (never commit .env)

PORT=3000
JWT_SECRET=change-me-to-a-long-random-string

# Postgres (local Docker or Neon)
DB_URL=postgresql://user:pass@localhost:5432/smat

# Redis (local Docker or Upstash — use rediss:// for Upstash TLS)
REDIS_URL=redis://localhost:6379

# Vercel + Neon integration may set these instead of DB_URL (app reads them automatically):
# POSTGRES_URL=
# DATABASE_URL=

# Optional Upstash alias (if your integration sets it):
# UPSTASH_REDIS_URL=
